APP_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
API_VERSION=v1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000,http://localhost:8080
ENABLE_VERBOSE_LOGS=true
ENABLE_GENKIT_DEBUG=true
AI_STEP_TIMEOUT_SECONDS=20

BOOTSTRAP_USER_ID=bootstrap-admin
BOOTSTRAP_DISPLAY_NAME=Atlas Administrator
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=changeme123
BOOTSTRAP_ROLES=admin

JWT_SECRET=replace-me-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-me-with-a-different-long-random-secret
JWT_ISSUER=atlas-ai-backend
JWT_AUDIENCE=atlas-ai-clients

DEFAULT_AI_PROVIDER=google

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
